{
  "name": "yohakuforce",
  "version": "0.7.0",
  "private": true,
  "description": "Salesforce 特化の AI 駆動プロジェクト推進基盤 OSS。属人化の解消・運用タスク自動化・AI 駆動開発の再現性を提供する。",
  "license": "Apache-2.0",
  "homepage": "https://github.com/yohakuforce/core",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:golden": "npm run test:golden --workspaces --if-present",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "salesforce",
    "ai",
    "claude-code",
    "knowledge-graph",
    "documentation",
    "onboarding",
    "release-management",
    "salesforce-dx"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yohakuforce/core"
  },
  "bugs": {
    "url": "https://github.com/yohakuforce/core/issues"
  }
}
